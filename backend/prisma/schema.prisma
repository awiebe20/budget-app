generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id               Int                      @id @default(autoincrement())
  name             String
  accountNumber    String?
  simplefinId      String?                  @unique
  bank             String?
  type             String
  balance          Decimal                  @default(0)
  balanceDate      DateTime?
  currency         String                   @default("USD")
  createdAt        DateTime                 @default(now())
  transactions     Transaction[]
  imports          ImportLog[]
  balanceSnapshots AccountBalanceSnapshot[]

  @@map("accounts")
}

model AccountBalanceSnapshot {
  id        Int      @id @default(autoincrement())
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  balance   Decimal
  date      DateTime

  @@unique([accountId, date])
  @@map("account_balance_snapshots")
}

model Category {
  id               Int            @id @default(autoincrement())
  name             String         @unique
  parentId         Int?
  parent           Category?      @relation("CategoryTree", fields: [parentId], references: [id])
  children         Category[]     @relation("CategoryTree")
  color            String?
  isIncome         Boolean        @default(false)
  isReimbursement  Boolean        @default(false)
  isFromSavings    Boolean        @default(false)
  paycheckTiming   String         @default("CURRENT")
  transactions     Transaction[]
  budgets          Budget[]

  @@map("categories")
}

model Transaction {
  id                  Int                @id @default(autoincrement())
  accountId           Int
  account             Account            @relation(fields: [accountId], references: [id])
  date                DateTime
  amount              Decimal
  merchantRaw         String
  merchantNormalized  String
  categoryId          Int?
  category            Category?          @relation(fields: [categoryId], references: [id])
  notes               String?
  reimbursedBy        String?
  savingsGoalId       Int?
  savingsGoal         SavingsGoal?       @relation(fields: [savingsGoalId], references: [id])
  source              String
  fingerprint         String             @unique
  isRecurring         Boolean            @default(false)
  isInternalTransfer  Boolean            @default(false)
  importId            Int?
  import              ImportLog?         @relation(fields: [importId], references: [id])
  splits              TransactionSplit[]
  createdAt           DateTime           @default(now())

  @@map("transactions")
}

model TransactionSplit {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  amount        Decimal
  owedBy        String
  settlementId  Int?
  settlement    Settlement? @relation(fields: [settlementId], references: [id])
  createdAt     DateTime    @default(now())

  @@map("transaction_splits")
}

model Settlement {
  id          Int                @id @default(autoincrement())
  person      String
  amount      Decimal
  periodStart DateTime
  periodEnd   DateTime
  settledDate DateTime
  splits      TransactionSplit[]
  createdAt   DateTime           @default(now())

  @@map("settlements")
}

model Budget {
  id            Int      @id @default(autoincrement())
  categoryId    Int
  category      Category @relation(fields: [categoryId], references: [id])
  amount        Decimal
  frequency     String   @default("MONTHLY")
  effectiveFrom DateTime
  createdAt     DateTime @default(now())

  @@unique([categoryId, effectiveFrom])
  @@map("budgets")
}

model SavingsGoal {
  id                Int           @id @default(autoincrement())
  name              String
  targetAmount      Decimal
  allocationPercent Float         @default(0)
  color             String?
  createdAt         DateTime      @default(now())
  transactions      Transaction[]

  @@map("savings_goals")
}

model ImportLog {
  id               Int           @id @default(autoincrement())
  accountId        Int
  account          Account       @relation(fields: [accountId], references: [id])
  source           String
  filename         String
  importedAt       DateTime      @default(now())
  transactionCount Int
  duplicateCount   Int
  status           String
  transactions     Transaction[]

  @@map("import_logs")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
